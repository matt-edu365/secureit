# PowerShell / tooling
*.log
*.tmp
*.bak

# Local editor files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Runtime/output artifacts
output/latest/*
output/history/*
!output/latest/.gitkeep
!output/history/.gitkeep
data/reports/*
!data/reports/.gitkeep

# Local tenant/runtime config
config/tenants.json
data/tenants.json
deploy/config.tenants.json
deploy/maester/tenants.json

# Published or generated sample site/report content
deploy/maester/*/latest/
deploy/maester/*/history/

# Secrets / local-only files
secrets/
*.pfx
*.cer
*.key
*.pem
.env
.env.*

# PHP / Apache noise
app/.phpunit.result.cache
